## Static response headers for Cloudflare Pages and Netlify.
## Flutter copies this file into the build/web deployment output.

/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin

## Never cache the bootstrap HTML/JS so new deploys appear immediately.
/index.html
  Cache-Control: no-cache
/flutter_bootstrap.js
  Cache-Control: no-cache
/flutter_service_worker.js
  Cache-Control: no-cache
/main.dart.js
  Cache-Control: no-cache
/version.json
  Cache-Control: no-cache

## Don't cache the icons/manifest so logo updates appear without a hard refresh.
/app_icon.png
  Cache-Control: no-cache
/favicon.png
  Cache-Control: no-cache
/manifest.json
  Cache-Control: no-cache
/icons/*
  Cache-Control: no-cache

## Revalidate Flutter assets so public runtime configuration cannot go stale.
/assets/*
  Cache-Control: public, max-age=0, must-revalidate

## CanvasKit files are versioned build artifacts and safe to cache long-term.
/canvaskit/*
  Cache-Control: public, max-age=31536000, immutable
