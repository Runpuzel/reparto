.packages
build/
*.iml
.idea/
.vscode/
ios/Pods/
android/.gradle/

# NOTE: env.txt and .env are intentionally NOT ignored.
# `env.txt` is bundled as a Flutter web asset (web hosts like Netlify hide
# dotfiles such as `.env`, so we use env.txt instead). It only contains PUBLIC
# client config (Supabase URL + anon key, Google web client id, feature flags).
# Row Level Security protects your data. Never put server secrets (service_role
# key, Paystack secret key, FCM server key) in this file.
